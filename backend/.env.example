PORT=3001
ALLOWED_ORIGINS=http://localhost:5173

# Plate lookup API configuration
# Choose one of the supported providers:
#
# 1. BrasilAPI (Free, no key required) - Recommended for testing
#    PLATE_API_PROVIDER=brasilapi
#
# 2. ApiPlaca (Paid service)
#    PLATE_API_PROVIDER=apiplaca
#    PLATE_API_KEY=your_apiplaca_key_here
#
# 3. PlacaFipe (Paid service)
#    PLATE_API_PROVIDER=placafipe
#    PLATE_API_KEY=your_placafipe_key_here
#
# 4. Custom API
#    PLATE_API_PROVIDER=custom
#    PLATE_API_URL=https://your-api.com/consulta/{plate}
#    PLATE_API_KEY=your_api_key_here

# Example for BrasilAPI (free):
PLATE_API_PROVIDER=brasilapi

# If using a paid service, uncomment and configure:
# PLATE_API_KEY=your_key_here
# PLATE_API_URL=https://api.example.com/{plate}
